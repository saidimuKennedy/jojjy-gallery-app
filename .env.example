# Copy to .env.local for local dev.
# On Vercel: Project → Settings → Environment Variables (Production + Preview).
# Audit: npm run audit:env

# ── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Auth (required in production) ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local only; on Vercel, inferred from VERCEL_URL if omitted
NEXTAUTH_URL=http://localhost:3000

# ── Display (optional) ──────────────────────────────────────────────────────
# ISO code shown on shop/events/account (defaults to USD)
NEXT_PUBLIC_CURRENCY=USD
# Canonical site URL for sitemap and SEO (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.jojjygallery.com
# E.164 without +, e.g. 254712345678 — enables WhatsApp button on artwork pages
NEXT_PUBLIC_ARTIST_WHATSAPP_NUMBER=

# ── Media / Cloudinary (optional — needed for signed music + uploads) ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Music (optional — dedicated play-token secret; falls back to NEXTAUTH_SECRET)
MUSIC_PLAY_SECRET=

# ── Paystack (required for Studio Shop / ticket checkout) ─────────────────────
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ── M-Pesa (optional — legacy artwork cart checkout only) ─────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ── Contact form email (optional) ─────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
CONTACT_FORM_RECIPIENT_EMAIL=
